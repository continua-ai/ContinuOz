# Database connection
# Local dev (SQLite/libSQL)
TURSO_DATABASE_URL=file:prisma/dev.db
# TURSO_AUTH_TOKEN=  # Only needed for remote Turso databases
DATABASE_URL=file:./prisma/dev.db  # Used by Prisma CLI (migrations, db push)

# Postgres (managed or docker-compose)
# DATABASE_URL=postgresql://oz:oz@localhost:5432/oz_workspace?schema=public

# NextAuth secret for JWT signing (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Warp API Key for Oz agent integration
# Create an API key in the Warp app: Settings > Platform
WARP_API_KEY=

# Optional: Override the Warp API base URL (defaults to https://app.warp.dev)
# WARP_API_URL=https://app.warp.dev

# Optional: Base URL for internal API calls (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js base URL (required in production for host validation)
# AUTH_URL=https://your-domain.example.com
# For IP/HTTP deployments, set true to trust forwarded host headers
# AUTH_TRUST_HOST=true

# Warp Environment ID for running agents
# Get environment IDs from the Warp dashboard or CLI
WARP_ENVIRONMENT_ID=

# Agent Callback URL - Required for Oz agents to send responses back
# The agent runs in a cloud sandbox and needs a publicly accessible URL to POST its response.
#
# Use ngrok to expose your local server:
#   1. Install ngrok: brew install ngrok
#   2. Run: ngrok http 3000
#   3. Copy the https URL and set it here
AGENT_CALLBACK_URL=

# Agent API Key - Used to authenticate agent callbacks back to this server
# Generate with: openssl rand -base64 32
AGENT_API_KEY=

# Agent routing mode
# - ic_only (default): agent dispatch is based only on intent classifier output
# - hybrid: direct @mentions dispatch first, then classifier evaluates unmentioned agents
AGENT_ROUTING_MODE=ic_only

# Intent Classifier (IC) API - optional
# If unset, IC selection returns empty and no agents are auto-dispatched in ic_only mode.
INTENT_CLASSIFIER_URL=
# Optional bearer token for the classifier API
INTENT_CLASSIFIER_API_KEY=
# Optional timeout in milliseconds (default: 8000)
INTENT_CLASSIFIER_TIMEOUT_MS=8000
# Optional confidence threshold when using decision arrays (default: 0.5)
INTENT_CLASSIFIER_MIN_CONFIDENCE=0.5
# Optional audience for GCP identity token auth to classifier (defaults to INTENT_CLASSIFIER_URL)
INTENT_CLASSIFIER_AUDIENCE=
# Optional threshold for boolean classifier responses (default: 0.75)
INTENT_CLASSIFIER_THRESHOLD=0.75
